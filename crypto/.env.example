# Wallet that deploys + owns the contracts. Use a FRESH wallet, not your main one.
# Export from MetaMask: Account details -> Show private key. Paste it here with the 0x prefix.
PRIVATE_KEY=0xyour_private_key_here

# RPC endpoints. Defaults work, but a paid provider (Alchemy/QuickNode) is more reliable.
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: lets you publish source code on basescan.org so people can read your contract.
# Free key from https://basescan.org/myapikey
BASESCAN_API_KEY=

# Token config (used by scripts/deploy.js)
TOKEN_NAME=Fan Coin
TOKEN_SYMBOL=FAN
TOKEN_MAX_SUPPLY=1000000000

# NFT config
NFT_NAME=Fan Pass
NFT_SYMBOL=FANPASS
NFT_BASE_URI=ipfs://REPLACE_WITH_YOUR_CID/
NFT_MAX_SUPPLY=10000
NFT_PUBLIC_PRICE_ETH=0.001
